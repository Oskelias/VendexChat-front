- RegisterPage: agrega inputs de contraseña y confirmar contraseña
- RegisterPage: elimina el aviso "Te enviaremos email para establecer contraseña"
- RegisterPage: actualiza pantalla de éxito (confirmar cuenta, no establecer contraseña)
- RegisterPage: validación de contraseña (mínimo 8 chars, coincidencia)
- AuthContext: interfaz register incluye campo password
- AuthContext: implementación usa supabase.auth.signUp() con password y metadata completa
  (nombre, slug, país, ciudad) para que el trigger handle_new_user cree la tienda
---
 src/contexts/AuthContext.tsx    | 21 ++++++++++++++++----
 src/pages/auth/RegisterPage.tsx | 35 +++++++++++++++++++++++++--------
 2 files changed, 44 insertions(+), 12 deletions(-)

diff --git a/src/contexts/AuthContext.tsx b/src/contexts/AuthContext.tsx
index 1615a38..532f22f 100644
--- a/src/contexts/AuthContext.tsx
+++ b/src/contexts/AuthContext.tsx
@@ -10,7 +10,7 @@ interface AuthContextType {
   token: string | null
   loading: boolean
   login: (email: string, password: string) => Promise<void>
-  register: (data: { store_name: string; email: string; slug: string; country: string; city: string }) => Promise<void>
+  register: (data: { store_name: string; email: string; slug: string; country: string; city: string; password: string }) => Promise<void>
   logout: () => void
   isAuthenticated: boolean
   isSuperadmin: boolean
@@ -124,9 +124,22 @@ export function AuthProvider({ children }: { children: ReactNode }) {
     setSelectedStoreId(null)
   }, [])
 
-  const register = useCallback(async (data: { store_name: string; email: string; slug: string; country: string; city: string }) => {
-    await authApi.register(data)
-    // No se inicia sesión: el usuario debe establecer su contraseña desde el email
+  const register = useCallback(async (data: { store_name: string; email: string; slug: string; country: string; city: string; password: string }) => {
+    const { error } = await supabase.auth.signUp({
+      email: data.email,
+      password: data.password,
+      options: {
+        data: {
+          name: data.store_name,
+          slug: data.slug,
+          country: data.country,
+          city: data.city,
+        },
+      },
+    })
+    if (error) throw new Error(error.message)
+    // El trigger handle_new_user crea el perfil y la tienda automáticamente.
+    // onAuthStateChange establecerá la sesión cuando el usuario confirme su email.
   }, [])
 
   const logout = useCallback(() => {
